# Copy to .env locally and keep the real file untracked.
STEP_API_KEY=
STEP_BASE_URL=https://api.stepfun.com/step_plan/v1
STEP_MODEL=step-3.7-flash

# Safe default. The DGX competition instance may use flux2-klein-4b after its
# local A/B gate passes; every candidate failure returns to the FLUX.1 path.
EVOLAB_IMAGE_RENDERER=flux1
EVOLAB_IMAGE_FALLBACK=flux1

# optional: reviewer failure falls back to the deterministic rules gate.
# required: reviewer failure blocks before image generation.
EVOLAB_REVIEW_MODE=optional

# The multimodal image reviewer runs after reference-conditioned renders.
# required fails closed; optional keeps an explicit technical-only record.
EVOLAB_VISUAL_REVIEW_MODE=optional
